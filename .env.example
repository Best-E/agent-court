# Wallet
PRIVATE_KEY=0xac0974bec... # deployer wallet private key. NEVER commit this

# RPCs - Get free keys from Alchemy/Infura if needed
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_RPC=https://mainnet.base.org

# Block explorer verification
BASESCAN_API_KEY=YourBasescanApiKeyHere

# Chainlink Functions
FUNCTIONS_SUBSCRIPTION_ID=123 # Create at https://functions.chain.link
# After deploy, add LLMJuryVerifier as consumer + fund with LINK
# Encrypt OpenAI key: npx @chainlink/functions-toolkit encrypt-secret --data YOUR_OPENAI_KEY
# Store the encrypted secret on-chain or pass via --secrets in request

# Gas reporting
REPORT_GAS=true # set to true to get gas report on `npm run test:gas`
COINMARKETCAP_API_KEY=YourCMCKey # optional, for USD costs in gas reporter
