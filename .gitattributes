# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Force Solidity to use LF
*.sol text eol=lf

# Force JS/TS/JSON to use LF  
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.md text eol=lf

# Exclude from exports
.gitattributes export-ignore
.gitignore export-ignore
.env export-ignore
.env.example export-ignore

# Treat as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
